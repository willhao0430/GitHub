      totalClientOverLimit += r.outOfLimitCost;
      totalClientCompanion += r.companionCost;
      totalTrips += r.tripCount;
    });

    const totalClientPay = totalClientCoPay + totalClientOverDistance + totalClientOverLimit + totalClientCompanion;
    const grandTotal = totalGov + totalClientPay;

