  // 當前地區與身分的費率規則
  const rules = useMemo(() => {
    // 自付額比例 (一般戶 21%, 中低收入 7%, 低收入 0%)
    let coPayRate = 0.21;
    if (identityType === '中低收入戶') coPayRate = 0.07;
    if (identityType === '低收入戶') coPayRate = 0;

    // 地區設定 (一趟基礎車資, 里程上限)
    let basePrice = 250;
    let maxFreeDistance = 20;
    
    if (areaType === '偏遠地區') {
      basePrice = 300;
      maxFreeDistance = 25;
    }

    return { coPayRate, basePrice, maxFreeDistance };
  }, [identityType, areaType]);

