  const analyzedRecords = useMemo(() => {
    let accumulatedTrips = 0;

    return records.map((record) => {
      // 判斷這一筆紀錄佔用幾趟 (單程=1趟, 來回=2趟)
      const currentTripCount = record.type === '來回' ? 2 : 1;
      
      let subsidyTripsThisRecord = 0; // 此筆紀錄中，可享有補助的趟數
      let selfPayTripsThisRecord = 0; // 此筆紀錄中，超出補助上限（自費）的趟數

      // 依序分配補助額度
      for (let i = 0; i < currentTripCount; i++) {
        if (accumulatedTrips < MAX_SUBSIDY_TRIPS) {
          subsidyTripsThisRecord++;
        } else {
          selfPayTripsThisRecord++;
        }
        accumulatedTrips++;
      }

      // 里程計算 (以單趟為單位計算。如果是來回，里程會套用兩次計算)
      const overDistancePerTrip = Math.max(0, record.distance - rules.maxFreeDistance);
      const overDistanceCostPerTrip = overDistancePerTrip * 10; // $10/km

      // 1. 補助額度內的車資計算
      const subsidyBaseCost = subsidyTripsThisRecord * rules.basePrice;
      const coPayInLimit = Math.round(subsidyBaseCost * rules.coPayRate); // 自付額部分
      const govSubsidy = subsidyBaseCost - coPayInLimit; // 政府補助部分

      // 2. 超出 8 趟限制的車資計算 (全額自費)
      const outOfLimitCost = selfPayTripsThisRecord * rules.basePrice;

      // 3. 超里程自費額 (不論是否在補助趟數內，超過的里程皆為自費，來回程若都超里程則 * 2)
      const totalOverDistanceCost = overDistanceCostPerTrip * currentTripCount;

      // 4. 陪同者自費費用 (假設陪同者每趟自費 $50 作為示範規則，可自行調整)
      const companionCost = record.companion ? (50 * currentTripCount) : 0;

      // 彙整此筆紀錄的金額
      const totalCost = (currentTripCount * rules.basePrice) + totalOverDistanceCost + companionCost;
      const clientTotalPay = coPayInLimit + outOfLimitCost + totalOverDistanceCost + companionCost;

      return {
        ...record,
        tripCount: currentTripCount,
        subsidyTrips: subsidyTripsThisRecord,
        selfPayTrips: selfPayTripsThisRecord,
        overDistanceCost: totalOverDistanceCost,
        companionCost,
        govSubsidy,
        coPayInLimit,
        outOfLimitCost,
        clientTotalPay,
        totalCost,
        isOverLimit: selfPayTripsThisRecord > 0
      };
    });
  }, [records, rules]);

